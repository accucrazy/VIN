# ============================================================
# VIN-AIOS · on-premise-first AI agent harness
# ============================================================
# Out of the box VIN runs entirely on your own machine via Ollama.
# Nothing here is shared with any cloud provider unless you
# explicitly enable GEMINI_API_KEY at the bottom of this file.

# --- Which provider VIN should use (ollama | openai | gemini) ---
# ollama   native /api/chat (recommended — keep_alive, embeddings, tool detect)
# openai   any OpenAI-compatible endpoint (vLLM / LM Studio / llama.cpp / cloud)
# gemini   Google cloud (opt-in only)
HARNESS_PROVIDER=ollama

# ============================================================
# Provider 1 · Ollama native (default, on-prem)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# 5m (default) · 24h · 0 (unload after request) · -1 (keep forever)
OLLAMA_KEEP_ALIVE=5m

# ============================================================
# Provider 2 · OpenAI-compatible (vLLM / LM Studio / llama.cpp / TGI / cloud)
# ============================================================
# Local example: a vLLM server serving qwen2.5:14b on :8000
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=local-no-key-needed
# OPENAI_MODEL=qwen2.5:14b
#
# OpenAI cloud example:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Provider 3 · Gemini (opt-in cloud burst)
# ============================================================
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash

# ============================================================
# Embeddings (used by memory hybrid search)
# ============================================================
# Defaults to Ollama's nomic-embed-text (768 dim, CPU-friendly).
# Other on-prem options: mxbai-embed-large (1024d), bge-m3 (1024d, multilingual).
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ============================================================
# Storage
# ============================================================
SQLITE_DB_PATH=./vin.db
# MEMORY_BACKEND=sqlite   # or 'inmemory' for tests

# ============================================================
# Web search (used by the web_search tool / web UI)
# ============================================================
# Pluggable provider model (à la Hermes Agent): the registry auto-detects which
# backend to use based on which var below is set, and falls through on failure.
# Priority: tavily > brave > serper > searxng > browser > ddg-instant.
# Optionally pin one with SEARCH_PROVIDER (name): tavily | brave | serper |
# searxng | browser | ddg-instant.
# SEARCH_PROVIDER=

# --- Keyed providers (best quality; pick ONE, all have free tiers) ---
# TAVILY_API_KEY=        # https://tavily.com  (AI-oriented, ~1000/mo free)
# BRAVE_API_KEY=         # https://brave.com/search/api
# SERPER_API_KEY=        # https://serper.dev  (Google results)

# --- SearXNG (self-hosted, no key, privacy-friendly) ---
# Point at a running instance whose settings.yml enables JSON output.
# SEARXNG_URL=http://localhost:8080

# --- Browser / computer-use (no key, drives a REAL Chrome via CDP) ---
# No config needed if Chrome/Chromium/Brave/Edge is installed in a standard
# location. Override the binary path if auto-detection fails:
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# --- ddg-instant (no key, last resort) ---
# DuckDuckGo Instant Answer API. Entity abstracts only — NOT real web results.
# Always available as the final fallback; nothing to configure.
